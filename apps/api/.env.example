# K-IREA API environment variables
ENVIRONMENT=production

# Database (Supabase — connection string from Supabase dashboard > Settings > Database > URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Security
SECRET_KEY=replace-with-random-64-char-string
ALGORITHM=HS256

# Cloudflare Access (Zero Trust dashboard > Access > Applications > your app > Overview)
CF_ACCESS_TEAM_DOMAIN=yourhouse.cloudflareaccess.com
CF_ACCESS_AUD=replace-with-aud-tag-from-cf-access

# Frontend URLs (for CORS — update after deploying admin to Pages)
ADMIN_URL=https://admin.yourhouse.ph
WEB_URL=https://yourhouse.ph

# Integrations
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
ELEVENLABS_API_KEY=your-elevenlabs-api-key
CALCOM_API_KEY=your-calcom-api-key

# App
DEBUG=False
